<Window x:Class="ProgPoePart_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0D1B2A">

    <Grid>
        <TabControl Margin="10">
            <!-- Chatbot Tab -->
            <TabItem Header="Chatbot">
                <Grid>
                    <!-- Title -->
                    <TextBlock Text="Cybersecurity Awareness Chatbot"
                               FontSize="26" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>

                    <!-- Your Image -->
                    <Image HorizontalAlignment="Left"
                           Height="261"
                           Margin="30,70,0,0"
                           VerticalAlignment="Top"
                           Width="407"
                           Source="/suttlemedia-cyborg-8147987_1920 - Copy.jpg"/>

                    <!-- Chat Display -->
                    <Border Background="White" CornerRadius="10" Margin="470,70,30,170">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="ChatDisplay"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     FontSize="14"
                                     Background="White"
                                     BorderThickness="0"
                                     Padding="10"/>
                        </ScrollViewer>
                    </Border>

                    <!-- User Input -->
                    <TextBox x:Name="UserInput"
                             Height="45" Width="650"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Bottom"
                             Margin="0,0,0,90"
                             FontSize="16"
                             Padding="10"
                             Background="White"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,25">
                        <Button x:Name="SendButton" Content="Send"
                                Width="120" Height="45" Margin="10"
                                Background="#1B9AAA" Foreground="White"
                                FontWeight="Bold"
                                Click="SendButton_Click"/>
                        <Button x:Name="ClearButton" Content="Clear Chat"
                                Width="120" Height="45" Margin="10"
                                Background="#E63946" Foreground="White"
                                FontWeight="Bold"
                                Click="ClearButton_Click"/>
                        <Button x:Name="ExitButton" Content="Exit"
                                Width="120" Height="45" Margin="10"
                                Background="#6C757D" Foreground="White"
                                FontWeight="Bold"
                                Click="ExitButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Task Assistant Tab -->
            <TabItem Header="Tasks">
                <StackPanel Margin="10">
                    <TextBlock Text="Add a New Task" FontWeight="Bold" Margin="0,5"/>
                    <TextBox x:Name="TaskTitleBox" Margin="0,5"/>
                    <TextBox x:Name="TaskDescriptionBox" Margin="0,5"/>
                    <TextBox x:Name="TaskReminderBox" Margin="0,5"/>
                    <Button Content="Add Task" Click="AddTask_Click" Margin="0,5"/>
                    <DataGrid x:Name="TaskGrid" AutoGenerateColumns="True" Height="200" Margin="0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Button Content="Mark Complete" Click="CompleteTask_Click" Margin="5"/>
                        <Button Content="Delete Task" Click="DeleteTask_Click" Margin="5"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Quiz Tab -->
            <TabItem Header="Quiz">
                <StackPanel Margin="10">
                    <TextBlock x:Name="QuizQuestionText" FontSize="16" Margin="0,5"/>
                    <ListBox x:Name="QuizOptionsList" Margin="0,5"/>
                    <Button Content="Submit Answer" Click="SubmitAnswer_Click" Margin="0,5"/>
                    <TextBlock x:Name="QuizFeedbackText" Margin="0,5"/>
                    <TextBlock x:Name="QuizScoreText" Margin="0,5"/>
                    <Button Content="Next Question" Click="NextQuestion_Click" Margin="0,5"/>
                </StackPanel>
            </TabItem>

            <!-- Activity Log Tab -->
            <TabItem Header="Activity Log">
                <StackPanel Margin="10">
                    <TextBlock Text="Recent Actions:" FontWeight="Bold"/>
                    <TextBox x:Name="LogDisplay" IsReadOnly="True" Height="200" TextWrapping="Wrap"/>
                    <Button Content="Show More" Click="ShowMoreLog_Click" Margin="0,5"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
